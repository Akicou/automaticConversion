# GGUF Forge Configuration
# Copy this file to .env and fill in your values

# HuggingFace Token (required for downloads and uploads)
HF_TOKEN=your_huggingface_token

# HuggingFace OAuth (optional, for user login)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# Parallel Quantization Jobs (default: 2)
# How many quantizations to run simultaneously. Each job gets total_cores / jobs threads.
# PARALLEL_QUANT_JOBS=2

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# Server host and port (optional)
# HOST=0.0.0.0
# PORT=8000

# ===========================================
# MODEL STORAGE CONFIGURATION
# ===========================================

# Model Download Path (optional)
# Where models are downloaded and processed. Supports:
# - Absolute path: D:\Models or /mnt/external/models
# - Relative path: ./models (relative to app directory)
# Priority: MODEL_DOWNLOAD_PATH > HF_HOME > default .cache folder
MODEL_DOWNLOAD_PATH=

# You can also use HuggingFace's HF_HOME environment variable
# If MODEL_DOWNLOAD_PATH is not set, HF_HOME will be used as fallback
# HF_HOME=/path/to/hf/cache

# ===========================================
# LLAMA.CPP SOURCE CONFIGURATION
# ===========================================

# Custom llama.cpp git repository (optional).
# Use this to point GGUF Forge at a fork that supports a model the upstream
# repo doesn't yet handle. Default: https://github.com/ggerganov/llama.cpp
# LLAMA_CPP_REPO=https://github.com/your-fork/llama.cpp

# Local folder where llama.cpp is cloned and built (optional).
# - Absolute path: D:\llama.cpp or /opt/llama.cpp
# - Relative path: ./llama.cpp (relative to app directory)
# Default: ./llama.cpp (subdirectory of the app)
# LLAMA_CPP_DIR=./llama.cpp

# Fork-specific compact GGUF --outtype values (optional, comma-separated).
# Some forks require converting directly to a compact GGUF type and skipping
# the standard llama-quantize step. List the outtypes the configured fork
# exposes here; users will be able to pick one in the conversion form.
# Example for antirez/llama.cpp-deepseek-v4-flash:
# LLAMA_CPP_OUTTYPES=iq2_xxs,iq2_xs,q2_k,tq2_0,tq1_0,q8_0

# All three of the above can also be changed at runtime by an admin on the
# /settings page (DB-backed override; takes precedence over these env vars).

# ===========================================
# ADMIN CONFIGURATION
# ===========================================

# Admin Users - comma-separated list of HuggingFace usernames
# These users will automatically get admin privileges when they login via OAuth
# Example: ADMIN_USERS=Akicuo,ungsung,someotheruser
ADMIN_USERS=

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Database type: "sqlite" (default) or "mssql"
DB_TYPE=sqlite

# MSSQL Configuration (only needed if DB_TYPE=mssql)
MSSQL_HOST=your-server.database.net
MSSQL_PORT=1433
MSSQL_DATABASE=gguforge
MSSQL_USER=your_username
MSSQL_PASSWORD=your_password
MSSQL_ENCRYPT=yes
MSSQL_TRUST_CERT=yes
# MSSQL_DRIVER=ODBC Driver 18 for SQL Server  # Optional: override auto-detection

# MSSQL Timeout Settings (optional)
# MSSQL_CONN_TIMEOUT=60
# MSSQL_LOGIN_TIMEOUT=60

# ===========================================
# DATABASE POOL CONFIGURATION (MSSQL only)
# ===========================================

# Connection pool settings for MSSQL (optional)
# DB_POOL_MIN=2
# DB_POOL_MAX=10
