# GGUF Forge Configuration
# Copy this file to .env and fill in your values

# HuggingFace Token (required for downloads and uploads)
HF_TOKEN=your_huggingface_token

# HuggingFace OAuth (optional, for user login)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# Server host and port (optional)
# HOST=0.0.0.0
# PORT=8000

# Parallel Quantization Jobs (default: 2)
# Number of quants to process simultaneously. Each job gets total_cores / jobs threads.
# Set to 1 for sequential processing (uses all cores, saves disk space)
# Set to 2-4 for parallel processing (faster, but uses more disk space temporarily)
PARALLEL_QUANT_JOBS=2

# ===========================================
# MODEL STORAGE CONFIGURATION
# ===========================================

# Model Download Path (optional)
# Where models are downloaded and processed. Supports:
# - Absolute path: D:\Models or /mnt/external/models
# - Relative path: ./models (relative to app directory)
# Priority: MODEL_DOWNLOAD_PATH > HF_HOME > default .cache folder
MODEL_DOWNLOAD_PATH=

# You can also use HuggingFace's HF_HOME environment variable
# If MODEL_DOWNLOAD_PATH is not set, HF_HOME will be used as fallback
# HF_HOME=/path/to/hf/cache

# ===========================================
# ADMIN CONFIGURATION
# ===========================================

# Admin Users - comma-separated list of HuggingFace usernames
# These users will automatically get admin privileges when they login via OAuth
# Example: ADMIN_USERS=Akicuo,ungsung,someotheruser
ADMIN_USERS=

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Database type: "sqlite" (default) or "mssql"
DB_TYPE=sqlite

# MSSQL Configuration (only needed if DB_TYPE=mssql)
MSSQL_HOST=your-server.database.net
MSSQL_PORT=1433
MSSQL_DATABASE=gguforge
MSSQL_USER=your_username
MSSQL_PASSWORD=your_password
MSSQL_ENCRYPT=yes
MSSQL_TRUST_CERT=yes
# MSSQL_DRIVER=ODBC Driver 18 for SQL Server  # Optional: override auto-detection

# MSSQL Timeout Settings (optional)
# MSSQL_CONN_TIMEOUT=60
# MSSQL_LOGIN_TIMEOUT=60

# ===========================================
# DATABASE POOL CONFIGURATION (MSSQL only)
# ===========================================

# Connection pool settings for MSSQL (optional)
# DB_POOL_MIN=2
# DB_POOL_MAX=10
